# Local config — contains personal values (domain, repo name, account ids, paths)
# Each has a corresponding *.example.* template that IS committed.
api/wrangler.toml

# Personal Claude Code context — instructions specific to this user's setup.
CLAUDE.md

# Secrets and state
.env
.dev.vars
.wrangler/
api/google-service-account.json

# BMAD-method installation artifacts (not part of the runtime)
_bmad/
_bmad-output/
.claude/

# Node
node_modules/
package-lock.json
yarn.lock

# OS
.DS_Store
Thumbs.db

# Sheet backups (operator scripts) — never commit financial data
scripts/_backups/

# Backstage: personal design notes + work-in-progress handoffs (real balances,
# debts, account ids) — never commit. The whole dev/ tree is local-only.
dev/

# Contains BIDV statement password hardcoded — never commit as-is
scripts/import-bidv.py
